rule-name-prefix DQC

/** V30 Release **/

ASSERT US.0237.10934 SATISFIED

$rule_id = (rule-name().split('.'))[rule-name().split('.').length];

/** DQCRT RULE **/
if not applicable_form(rule-name())
	skip
else


/** Identify all presentation networks in the company extension **/

	$allNetworks = $PRES_NETWORKS;

	/** eliminate reports with no presentations containing a statement **/

	$fsNetworks = filter $allNetworks where $item.role.description.contains('- Statement ');
	
	if $fsNetworks.length == 0
			skip
	else
		/** Get all concepts in FS Networks **/
		$fsConcepts = sum(set(for ($network in $fsNetworks)
								$network.concepts));

		/** Get those concepts that are monetary items **/					
		$fsConcepts = (filter $fsConcepts where $item.is-monetary returns $item.name).to-set


		/** Get Balance SHeet Location Axis Members **/

		$facts_using_BS_location_axis = list({covered nonils @StatementOfFinancialPositionLocationBalanceAxis = *})
		$bs_location_members = (filter $facts_using_BS_location_axis returns $item.dimension(StatementOfFinancialPositionLocationBalanceAxis).name).to-set
		for $member in $bs_location_members
			if ($fsConcepts.intersect($member)).length > 0
				false
			else
				true

message
"The filer has used the StatementOfFinancialPositionLocationBalanceAxis with a value of {$member} in the filing. This member is used to identify the location of the line item in the balance sheet. However, the concept {$member.local-name} does not appear in the face financial statements.

Rule Element Id:{$rule_id}
Rule version: {$ruleVersion}"

severity error  
effectiveDate $effective_dates[$rule_id]


ASSERT US.0237.10935 SATISFIED

$rule_id = (rule-name().split('.'))[rule-name().split('.').length];

/** DQCRT RULE **/
if not applicable_form(rule-name())
	skip
else


	/** Identify all presentation networks in the company extension **/

		$allNetworks = $PRES_NETWORKS;

		/** eliminate reports with no presentations containing a statement **/

		$fsNetworks = filter $allNetworks where $item.role.description.contains('- Statement ');
		
		if $fsNetworks.length == 0
				skip
		else
			/** Get all concepts in FS Networks **/
			$fsConcepts = sum(set(for ($network in $fsNetworks)
									$network.concepts));

			/** Get those concepts that are monetary items **/					
			$fsConcepts = (filter $fsConcepts where $item.is-monetary returns $item.name).to-set


			/** Get Income Location Axis Members **/

			$facts_using_BS_location_axis = list({covered nonils @StatementOfIncomeLocationBalanceAxis = *})
			$bs_location_members = (filter $facts_using_BS_location_axis returns $item.dimension(StatementOfIncomeLocationBalanceAxis).name).to-set
			for $member in $bs_location_members
				if ($fsConcepts.intersect($member)).length > 0
					false
				else
					true

message
"The filer has used the StatementOfIncomeLocationBalanceAxis with a value of {$member} in the filing. This member is used to identify the location of the line item in the income statement. However, the concept {$member.local-name} does not appear in the face financial statements.

Rule Element Id:{$rule_id}
Rule version: {$ruleVersion}"

severity error  
effectiveDate $effective_dates[$rule_id]


ASSERT US.0237.10936 SATISFIED

$rule_id = (rule-name().split('.'))[rule-name().split('.').length];

/** DQCRT RULE **/
if not applicable_form(rule-name())
	skip
else


	/** Identify all presentation networks in the company extension **/

		$allNetworks = $PRES_NETWORKS;

		/** eliminate reports with no presentations containing a statement **/

		$fsNetworks = filter $allNetworks where $item.role.description.contains('- Statement ');
		
		if $fsNetworks.length == 0
				skip
		else
			/** Get all concepts in FS Networks **/
			$fsConcepts = sum(set(for ($network in $fsNetworks)
									$network.concepts));

			/** Get those concepts that are monetary items **/					
			$fsConcepts = (filter $fsConcepts where $item.is-monetary returns $item.name).to-set


			/** Get Other Comprehensive Income Location Axis Members **/

			$facts_using_BS_location_axis = list({covered nonils @OtherComprehensiveIncomeBalanceAxis = *})
			$bs_location_members = (filter $facts_using_BS_location_axis returns $item.dimension(OtherComprehensiveIncomeBalanceAxis).name).to-set
			for $member in $bs_location_members
				if ($fsConcepts.intersect($member)).length > 0
					false
				else
					true

message
"The filer has used the OtherComprehensiveIncomeBalanceAxis with a value of {$member} in the filing. This member is used to identify the location of the line item in the other comprehensive income statement. However, the concept {$member.local-name} does not appear in the face financial statements.

Rule Element Id:{$rule_id}
Rule version: {$ruleVersion}"

severity error  
effectiveDate $effective_dates[$rule_id]

